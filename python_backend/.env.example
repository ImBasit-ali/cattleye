# Python backend — copy to .env (gitignored)
ENV=development
PORT=8000

# Relative to python_backend/ — put .pth and .pt files in python_backend/models/
MODELS_DIR=models

ALLOWED_ORIGINS=*

# TrOCR ear-tag OCR (downloads ~500 MB on first run)
ENABLE_EARTAG_OCR=true
TROCR_MODEL=microsoft/trocr-small-printed

# Render sets PORT automatically — do not override on the Render dashboard.
