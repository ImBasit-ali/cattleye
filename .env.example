# Flutter app — copy to .env (gitignored)

APP_ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Debug: PC / emulator
LOCAL_MODEL_BACKEND_URL=http://127.0.0.1:8000

# Release APK + local backend on PC (phone on same Wi‑Fi) — your PC IPv4:
RELEASE_LOCAL_BACKEND_URL=http://192.168.1.42:8000

# Release APK + Render (optional — leave empty for local PC backend)
RENDER_MODEL_BACKEND_URL=
MODEL_BACKEND_URL=
